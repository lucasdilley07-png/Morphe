rules_version = '2';

// Morphe — security rules (Phases 1–3).
// Phase 1: each user owns exactly their own profile document.
// Phase 3 (coach↔client, designed 2026-07-06): a coach with an ACTIVE
// connection may read a linked athlete's full profile and workout logs.
// Product decisions baked in here:
//   • Linking = reusable coach code + the coach approves each request.
//   • A linked coach sees the FULL athlete profile (incl. injuries, body
//     metrics, goals) — chosen for coaching quality over granular privacy.
//   • Coach signup is open; users/{uid}.coach.verified is reserved for a
//     future credential-check gate and can never be set true from the client.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Active coach↔client link. Connection ids are deterministic —
    // "{coachUid}_{athleteUid}" — so the check is a single doc lookup.
    function isActiveCoachOf(athleteUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/connections/$(request.auth.uid + '_' + athleteUid))
        && get(/databases/$(database)/documents/connections/$(request.auth.uid + '_' + athleteUid)).data.status == 'active';
    }

    // True when the write does NOT try to flip a verification flag to true.
    // Both the coach credential flag and the account-level verified badge are
    // granted ONLY from the console/a Function — a client-set checkmark would
    // be a forged trust signal. A client may keep an already-granted true
    // (checked at the call sites via resource) but never mint one.
    function keepsVerifiedHonest() {
      return request.resource.data.get('coach', {}).get('verified', false) != true
        && request.resource.data.get('verified', false) != true;
    }

    // The user's profile document. Private to its owner, plus read access
    // for an actively linked coach (full-profile decision above).
    match /users/{uid} {
      allow read:   if isOwner(uid) || isActiveCoachOf(uid);
      allow create: if isOwner(uid) && keepsVerifiedHonest();
      // Per-flag: a client may CARRY an already-granted true, never mint one.
      allow update: if isOwner(uid)
        && (request.resource.data.get('coach', {}).get('verified', false) != true
            || resource.data.get('coach', {}).get('verified', false) == true)
        && (request.resource.data.get('verified', false) != true
            || resource.data.get('verified', false) == true);
      allow delete: if false;   // account deletion goes through a Function later

      // The user's own workout data. Linked coaches read, never write.
      match /workoutLogs/{logId} {
        allow read:  if isOwner(uid) || isActiveCoachOf(uid);
        allow write: if isOwner(uid);
      }
      match /customWorkouts/{id} {
        allow read, write: if isOwner(uid);
      }

      // Personal appointments — one doc per appointment (append-scale, not a
      // state/* JSON blob). Owner-only ON PURPOSE: unlike workoutLogs there
      // is no coach read, because an appointment can name third parties
      // (withName) who never agreed to be visible to a linked coach.
      // NOTE: publishing these rules is manual — editing this file changes
      // nothing until `firebase deploy --only firestore:rules` (or a console
      // paste) pushes it to the morphe-3c5c2 project.
      match /appointments/{id} {
        allow read, write: if isOwner(uid);
      }

      // Feed bookmarks — one doc per saved post ({ savedAt }). Private on
      // purpose: what someone saves is their own business, so no coach read.
      match /savedPosts/{postId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Username uniqueness map. Readable by all (to check availability at
    // sign-up), claimable only by the signed-in user for their own uid.
    // Owners may re-write their own entry (a same-name re-claim is a no-op
    // write) and delete it — that's how a rename releases the old name in
    // the same transaction that claims the new one. A name someone ELSE
    // holds stays untouchable.
    match /usernames/{username} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Coach codes: ONE reusable, shareable code per coach (e.g. MORPHE-4X2K9).
    // Any signed-in user can resolve a code to a coach uid (that's how the
    // athlete's "enter your coach's code" field works). A coach claims a code
    // only for themself; codes are immutable from the client (rotation and
    // one-code-per-coach enforcement move to a Cloud Function later).
    match /coachCodes/{code} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.coachUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['coachUid', 'createdAt']);
      allow update, delete: if false;
    }

    // Coach↔client connections. Deterministic id "{coachUid}_{athleteUid}".
    // Lifecycle: athlete enters a coach code → creates a PENDING request →
    // the coach approves (active) or declines (declined) → either side can
    // end the link at any time (revoked). Revoking kills the coach's read
    // access instantly via isActiveCoachOf above.
    match /connections/{connId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.coachUid
            || request.auth.uid == resource.data.athleteUid);

      // Only the athlete creates a request, only as pending, only under the
      // deterministic id, and never to themself.
      allow create: if isSignedIn()
        && request.resource.data.athleteUid == request.auth.uid
        && request.resource.data.coachUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && connId == request.resource.data.coachUid + '_' + request.resource.data.athleteUid;

      // Participants move the status; the two uids are immutable.
      allow update: if isSignedIn()
        && request.resource.data.coachUid == resource.data.coachUid
        && request.resource.data.athleteUid == resource.data.athleteUid
        && (
          // The coach decides on a pending request…
          (request.auth.uid == resource.data.coachUid
            && resource.data.status == 'pending'
            && request.resource.data.status in ['active', 'declined'])
          // …and either side can revoke at any time.
          || ((request.auth.uid == resource.data.coachUid
               || request.auth.uid == resource.data.athleteUid)
              && request.resource.data.status == 'revoked')
        );

      allow delete: if false;
    }

    // Train Together parties. The 6-char doc id is the join code — knowing it
    // is the invite (read by code; no listing). Hosts create/steer the party;
    // every member owns exactly their own member doc.
    match /parties/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.hostID == request.auth.uid;
      allow update: if isSignedIn() && resource.data.hostID == request.auth.uid;
      allow delete: if false;

      match /members/{uid} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /nudges/{nudgeId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.fromID == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Verification requests (one per user, doc id = uid). The user submits a
    // selfie + note; the Morphe team reviews in the console and grants
    // users/{uid}.verified there — the client can only ever ask. Status is
    // console-managed after submission: the client writes exactly 'pending'
    // and may resubmit only while still pending (or after a 'declined').
    match /verificationRequests/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(
             ['uid', 'name', 'username', 'role', 'note', 'selfieJPEG', 'status', 'createdAt'])
        && request.resource.data.uid == uid;
      allow update: if isOwner(uid)
        && resource.data.status in ['pending', 'declined']
        && request.resource.data.status == 'pending'
        && request.resource.data.uid == uid;
      allow delete: if isOwner(uid);
    }

    // Coach-managed client profiles (pre-signup) + claim handoff.
    // The document id IS the invite code — possession of the code is the
    // authorization to claim, exactly like party join codes. The coach owns
    // the profile until the athlete claims it; after that it's frozen (the
    // history has moved into the athlete's own account).
    match /managedClients/{code} {
      // GET requires knowing the code (unguessable enough at 31^6); LIST is
      // restricted to the owning coach's own roster query.
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.coachUid == request.auth.uid;

      // Only a coach creates one, for themself, unclaimed.
      allow create: if isSignedIn()
        && request.resource.data.coachUid == request.auth.uid
        && request.resource.data.status == 'unclaimed';

      // Two legal updates:
      //   1. The owning coach edits/logs while the profile is unclaimed.
      //   2. Any signed-in athlete atomically claims an unclaimed profile for
      //      THEMSELF — flipping status and stamping claimedByUid, nothing else.
      allow update: if isSignedIn()
        && request.resource.data.coachUid == resource.data.coachUid
        && (
          (request.auth.uid == resource.data.coachUid
            && resource.data.status == 'unclaimed')
          || (resource.data.status == 'unclaimed'
            && request.resource.data.status == 'claimed'
            && request.resource.data.claimedByUid == request.auth.uid
            && request.resource.data.logsJSON == resource.data.logsJSON
            && request.resource.data.athleteID == resource.data.athleteID)
        );

      // A coach can delete an unclaimed profile; a claimed one is the
      // athlete's history now.
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.coachUid
        && resource.data.status == 'unclaimed';
    }

    // Weekly leaderboard — global, opt-in. weekKey is the Monday-anchored ISO
    // year-week ("2026-W30"); each signed-in user owns exactly one entry per
    // week (doc id = uid). Honesty guarantees enforced here:
    //   • a user writes ONLY their own row (no ghost competitors),
    //   • score/workouts must be non-negative integers,
    //   • `verified` may only mirror a badge the server actually granted
    //     (users/{uid}.verified) — no self-minted blue checks on the board,
    //   • no client deletes: leaving the board stops future posts, but the
    //     already-posted week stays (disclosed in the opt-in copy).
    // NOTE: publishing these rules is manual — editing this file changes
    // nothing until `firebase deploy --only firestore:rules` (or a console
    // paste) pushes it to the morphe-3c5c2 project.
    match /leaderboards/{weekKey}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.workouts is int
        && request.resource.data.workouts >= 0
        && (request.resource.data.get('verified', false) != true
            || get(/databases/$(database)/documents/users/$(uid)).data.get('verified', false) == true);
      allow delete: if false;
    }

    // Code-joinable challenges. The 6-char doc id is the join code — knowing
    // it is the invite (get by code; no listing), exactly like parties. The
    // host creates the challenge doc (immutable afterward, host-set window
    // capped at 30 days); every member owns exactly their own member doc,
    // with the same non-negative-score and honest-verified checks as the
    // weekly board.
    match /challenges/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 60
        && request.resource.data.metric in ['sets', 'workouts']
        && request.resource.data.startsAt is timestamp
        && request.resource.data.endsAt is timestamp
        && request.resource.data.endsAt.toMillis() > request.resource.data.startsAt.toMillis()
        && request.resource.data.endsAt.toMillis() - request.resource.data.startsAt.toMillis() <= 30 * 24 * 60 * 60 * 1000;
      allow update, delete: if false;

      match /members/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid)
          && request.resource.data.score is int
          && request.resource.data.score >= 0
          && (request.resource.data.get('verified', false) != true
              || get(/databases/$(database)/documents/users/$(uid)).data.get('verified', false) == true);
        allow delete: if false;
      }
    }

    // Real 1:1 coach↔athlete messaging. Thread id is deterministic —
    // "{coachUid}_{athleteUid}" — same scheme as connections, so both sides
    // derive the same doc without a lookup. Participants (and only they) read
    // and write; the uid/name fields freeze at creation; messages are
    // immutable once sent (honest history — no edits, no deletions). Rules
    // can't query managedClients by claimedByUid, so the real-link guarantee
    // is: the coach client only creates a thread from a CLAIMED roster entry,
    // and rules pin every thread to exactly its two named participants.
    // NOTE: publishing these rules is manual — editing this file changes
    // nothing until `firebase deploy --only firestore:rules` (or a console
    // paste) pushes it to the morphe-3c5c2 project.
    match /threads/{threadId} {
      function isThreadParticipant() {
        return isSignedIn()
          && (request.auth.uid == resource.data.coachUid
              || request.auth.uid == resource.data.athleteUid);
      }

      allow get: if isThreadParticipant();
      // list only via a participant-scoped query (whereField coachUid == me,
      // or whereField athleteUid == me — the store issues one of each).
      allow list: if isThreadParticipant();

      // A participant creates the thread under the deterministic id, never to
      // themself, with exactly the thread fields and a bounded preview.
      allow create: if isSignedIn()
        && threadId == request.resource.data.coachUid + '_' + request.resource.data.athleteUid
        && (request.auth.uid == request.resource.data.coachUid
            || request.auth.uid == request.resource.data.athleteUid)
        && request.resource.data.coachUid != request.resource.data.athleteUid
        && request.resource.data.keys().hasOnly(
             ['coachUid', 'athleteUid', 'coachName', 'athleteName',
              'lastMessage', 'lastSender', 'updatedAt'])
        && request.resource.data.coachName is string
        && request.resource.data.athleteName is string
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 300;

      // Participants may only roll the preview forward — uids and names are
      // immutable, and the preview sender must be the writer.
      allow update: if isThreadParticipant()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMessage', 'lastSender', 'updatedAt'])
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 300
        && request.resource.data.lastSender == request.auth.uid;

      allow delete: if false;

      match /messages/{msgId} {
        // Membership lives on the parent thread doc — one get() per rule.
        function parentData() {
          return get(/databases/$(database)/documents/threads/$(threadId)).data;
        }

        allow read: if isSignedIn()
          && (request.auth.uid == parentData().coachUid
              || request.auth.uid == parentData().athleteUid);

        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (request.auth.uid == parentData().coachUid
              || request.auth.uid == parentData().athleteUid)
          && request.resource.data.keys().hasOnly(['senderUid', 'text', 'sentAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 2000;

        // Messages are immutable — sent means sent.
        allow update, delete: if false;
      }
    }

    // Community feed — the real For You surface. One doc per post, visible to
    // every signed-in user. Honesty guarantees enforced here:
    //   • authorUid is always the writer (no ghost authors),
    //   • text is bounded 1..1000; workoutName ≤80; repostOfAuthor ≤60,
    //   • `verified` may only mirror a badge the server actually granted
    //     (users/{uid}.verified) — same pattern as the leaderboard entries,
    //     so no self-minted blue checks in the feed,
    //   • posts are immutable once published (edit = delete + repost),
    //   • only the author deletes their own post.
    // NOTE: publishing these rules is manual — editing this file changes
    // nothing until `firebase deploy --only firestore:rules` (or a console
    // paste) pushes it to the morphe-3c5c2 project.
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(
             ['authorUid', 'authorName', 'verified', 'text', 'workoutName',
              'repostOfId', 'repostOfAuthor', 'createdAt'])
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 1
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 1000
        && (!('workoutName' in request.resource.data)
            || (request.resource.data.workoutName is string
                && request.resource.data.workoutName.size() <= 80))
        && (!('repostOfId' in request.resource.data)
            || request.resource.data.repostOfId is string)
        && (!('repostOfAuthor' in request.resource.data)
            || (request.resource.data.repostOfAuthor is string
                && request.resource.data.repostOfAuthor.size() <= 60))
        && (request.resource.data.get('verified', false) != true
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('verified', false) == true);

      // Posts are immutable — published means published.
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.authorUid;

      // Reactions: one doc per user per post ({ value: true, createdAt }) —
      // the doc id IS the reactor's uid, so real counts come from counting
      // docs and nobody can inflate a post beyond their single reaction.
      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['value', 'createdAt'])
          && request.resource.data.value == true;
        allow update: if false;
        allow delete: if isOwner(uid);
      }
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
